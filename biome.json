{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noSvgWithoutTitle": "off",
				"useButtonType": "off",
				"useSemanticElements": "off",
				"useKeyWithClickEvents": "off"
			},
			"correctness": {
				"useJsxKeyInIterable": "warn"
			}
		}
	},
	"files": {
		"ignore": ["node_modules", "dist", "frontend/dist"]
	}
}
